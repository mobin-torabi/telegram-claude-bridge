# Copy this file to ".env" and fill in your values. .env is gitignored.

# From @BotFather after /newbot
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz

# Your personal Telegram numeric id (from @userinfobot). Only this id may use the bot.
ALLOWED_CHAT_ID=000000000

# Folder Claude works in by default. Use forward slashes or escaped backslashes.
WORKING_DIR=C:/Users/Asus

# Optional: pin a model (e.g. claude-opus-4-8). Leave blank for the default.
CLAUDE_MODEL=

# Optional: max seconds for a single task before it's cancelled.
CLAUDE_TIMEOUT=1800
